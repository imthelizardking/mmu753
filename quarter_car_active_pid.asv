%     text(act_x+act_w+0.02, (act_z1+act_z2)/2, ...
%          sprintf('F=%.0fN',F_act_log(i)), ...
%          'FontSize',10,'FontName','Verdana','Color',[0.8 0 0.5])
% 
%     % Tire contact point
%     plot(x_inst,u_vet(i),'ko','MarkerFaceColor','k','MarkerSize',10)
