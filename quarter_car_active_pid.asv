%          color(2,:),'LineWidth',2)
% 
%     % Passive spring + tire (same helper functions)
%     plotSpring(L0_u,L0_s,h_u,u_vet,z_s_active,z_u_active,i,x_inst)
%     plotDamper(L0_s,h_u,z_s_active,z_u_active,i,x_inst)
% 
%     % Actuator visualisation (filled rectangle in magenta between masses)
%     act_x  = x_inst + 0.1;
