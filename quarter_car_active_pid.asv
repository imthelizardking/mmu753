% 
%     set(gca,'xlim',[x_inst-l_win/2  x_inst+l_win/2], ...
%             'ylim',[-0.1  -0.1+l_win])
%     hold on ; grid on ; box on
%     plot([-10 X_r],[0 Z_r],'k','LineWidth',3)
