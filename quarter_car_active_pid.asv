% 
% %% =========================================================================
% %  Helper functions (identical to original passive code)
% % ==========================================================================
% 
% function plotSpring(L0_u,L0_s,h_u,u_vet,z_s,z_u,i,x_inst)
% 
%     rodPct      = 0.11;
%     springPct   = 1/3;
%     spring_wid  = 3;
% 
%     L_s = (z_s - (z_u+h_u)) - 2*rodPct*L0_s;
%     L_u = (z_u - u_vet)     - 2*rodPct*L0_u;
% 
%     c_s = x_inst-0.2;  w_s = 0.1;
%     c_u = x_inst;      w_u = 0.1;
% 
%     spring_u_X = [c_u; c_u; c_u+w_u; c_u-w_u; c_u+w_u; c_u-w_u; c_u+w_u; c_u-w_u; c_u; c_u];
%     spring_u_Z = [ u_vet(i);
%                    u_vet(i)+  rodPct*L0_u;
%                    u_vet(i)+  rodPct*L0_u;
%                    u_vet(i)+  rodPct*L0_u+  springPct*L_u(i);
%                    u_vet(i)+  rodPct*L0_u+  springPct*L_u(i);
%                    u_vet(i)+  rodPct*L0_u+2*springPct*L_u(i);
%                    u_vet(i)+  rodPct*L0_u+2*springPct*L_u(i);
%                    u_vet(i)+  rodPct*L0_u+3*springPct*L_u(i);
%                    u_vet(i)+  rodPct*L0_u+3*springPct*L_u(i);
%                    u_vet(i)+2*rodPct*L0_u+3*springPct*L_u(i)];
% 
%     spring_s_X = [c_s; c_s; c_s+w_s; c_s-w_s; c_s+w_s; c_s-w_s; c_s+w_s; c_s-w_s; c_s; c_s];
%     spring_s_Z = [ z_u(i)+h_u;
%                    z_u(i)+h_u +   rodPct*L0_s;
%                    z_u(i)+h_u +   rodPct*L0_s;
%                    z_u(i)+h_u +   rodPct*L0_s +   springPct*L_s(i);
%                    z_u(i)+h_u +   rodPct*L0_s +   springPct*L_s(i);
%                    z_u(i)+h_u +   rodPct*L0_s + 2*springPct*L_s(i);
%                    z_u(i)+h_u +   rodPct*L0_s + 2*springPct*L_s(i);
%                    z_u(i)+h_u +   rodPct*L0_s + 3*springPct*L_s(i);
%                    z_u(i)+h_u +   rodPct*L0_s + 3*springPct*L_s(i);
%                    z_u(i)+h_u + 2*rodPct*L0_s + 3*springPct*L_s(i)];
% 
%     plot(spring_u_X,spring_u_Z,'k','LineWidth',spring_wid)
%     plot(spring_s_X,spring_s_Z,'k','LineWidth',spring_wid)
% end
% 
% function plotDamper(L0_2,h1,z_s,z_u,i,x_inst)
% 
%     rodLowerPct  = 0.1;
%     rodUpperPct  = 0.4;
%     cylinderPct  = 0.4;
%     damper_line_wid = 3;
% 
%     c = 0.2+x_inst;  w = 0.05;
% 
%     rod_1_X = [c c];
%     rod_1_Z = [z_u(i)+h1  z_u(i)+h1+rodLowerPct*L0_2];
% 
%     c_X = [c-w; c-w; c+w; c+w];
%     c_Z = [z_u(i)+h1+rodLowerPct*L0_2+cylinderPct*L0_2;
%            z_u(i)+h1+rodLowerPct*L0_2;
%            z_u(i)+h1+rodLowerPct*L0_2;
%            z_u(i)+h1+rodLowerPct*L0_2+cylinderPct*L0_2];
% 
%     rod2X    = [c c];
%     rod2Z    = [z_s(i)  z_s(i)-rodUpperPct*L0_2];
%     pistonX  = [c-0.8*w  c+0.8*w];
%     pistonZ  = [z_s(i)-rodUpperPct*L0_2  z_s(i)-rodUpperPct*L0_2];
% 
%     plot(rod_1_X, rod_1_Z, 'k','LineWidth',damper_line_wid)
%     plot(rod2X,   rod2Z,   'k','LineWidth',damper_line_wid)
%     plot(pistonX, pistonZ, 'k','LineWidth',damper_line_wid)
%     plot(c_X,     c_Z,     'k','LineWidth',damper_line_wid)
% end
